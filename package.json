{
  "name": "salescore-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend && .venv\\Scripts\\pip install -r backend/requirements.txt",
    "start:frontend": "npm run dev --prefix frontend",
    "start:backend": ".venv\\Scripts\\uvicorn --app-dir backend main:app --reload",
    "start:backend:unix": ".venv/bin/uvicorn --app-dir backend main:app --reload",
    "dev": "concurrently --kill-others \"npm run start:frontend\" \"npm run start:backend\"",
    "dev:unix": "concurrently --kill-others \"npm run start:frontend\" \"npm run start:backend:unix\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0"
  }
}
